# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=LogHist API
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=["https://yourdomain.ru","https://t.me"]

# ─── MongoDB (Docker) ─────────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_APP_USER=loghist_app
MONGO_APP_PASSWORD=CHANGE_ME_APP_PASSWORD
MONGO_DB=loghist

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OpenAI / ChatGPT ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_WEBHOOK_HOST=https://yourdomain.ru
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_STRONG_SECRET

# ─── Encryption (FZ-152) ─────────────────────────────────────────────────────
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32BYTE_KEY

# ─── Admin panel ─────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=REPLACE_WITH_ADMIN_SECRET

# ─── Archive settings ────────────────────────────────────────────────────────
REQUEST_ARCHIVE_DAYS=30
REQUEST_ARCHIVE_NOTIFY_BEFORE_DAYS=3

# ─── OCR ─────────────────────────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGE=rus+eng

# ─── Mongo Express (UI) ──────────────────────────────────────────────────────
ME_BASICAUTH_USER=admin
ME_BASICAUTH_PASSWORD=CHANGE_ME
